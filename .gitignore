# --- Node / UI build ---
ui/node_modules/
ui/build/
ui/dist/
ui/.cache/
ui/coverage/
ui/*.log
ui/npm-debug.log*
ui/yarn-debug.log*
ui/yarn-error.log*

# --- Composer (not used at runtime, but ignore if ever added) ---
vendor/
composer.lock

# --- PHP / WP tooling ---
.phpunit.result.cache
.phpcs-cache
.phpcs.xml
.phpunit.xml
phpcs.xml
phpunit.xml

# --- Build & release artifacts ---
dist/
build/
*.zip
*.tar.gz

# --- WordPress.org listing assets (live only in the SVN repo's /assets/) ---
assets/img/Screenshot*.png
assets/img/screenshot-*.png
# Defensive: don't ever ship wp.org listing artwork from the repo root or
# from /assets/. These belong in the SVN /assets/ folder, not in trunk.
/banner-*.png
/icon-*.png
/screenshot-*.png

# --- Tooling / agent context (never relevant to the published plugin) ---
.claude/
.cursor/
CLAUDE.md
AGENTS.md
.aider*

# --- SVN-related local state (we use SVN only via dist/svn/, but if a
# stray .svn ever lands at the repo root or elsewhere outside dist/,
# don't ship it) ---
.svn/

# --- Editor / IDE ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.code-workspace
nbproject/
.project
.buildpath
.settings/

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Local env / secrets ---
.env
.env.*
!.env.example
*.local
secrets.json

# --- Logs ---
*.log
logs/

# --- Temp files ---
*.bak
*.swp
*.swo
*.tmp
*~
